# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# turbopack / build caches
.turbo
.swc

# production
/build

# misc
.DS_Store
*.pem

# local / editor
.idea/
*.sublime-project
*.sublime-workspace
.history/

# caches & temp
.cache/
.eslintcache
*.tmp
*.temp

# OS (Windows)
Thumbs.db
ehthumbs.db
Desktop.ini

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — реальные секреты не коммитим
.env
.env.local
.env.*.local
# .env.example НЕ игнорируем — это шаблон для команды и CI

# vercel
.vercel

# lighthouse / локальные HTML+JSON отчёты (не в репозиторий)
lighthouse-*.html
lighthouse-*.json

# typescript
*.tsbuildinfo
next-env.d.ts

# Служебные заметки, статусы и инструкции для агентов/IDE (не код сайта)
/AGENTS.md
/AGENT-TASK.md
/CLAUDE.md
/MEMORY.md
/PROJECT-RESUME.md
/STATUS-LOG.md
/TODO.md
/SEO-PLAN.md
/.cursor/

# Локальные материалы и выгрузки, не входящие в Next.js (макеты, zip, черновики)
/files/
/*.zip
