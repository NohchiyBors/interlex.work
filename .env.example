# ─────────────────────────────────────────────
# Cloudflare Turnstile (защита форм от ботов)
# ─────────────────────────────────────────────
# Получить ключи: https://dash.cloudflare.com/ → Turnstile → Add site
#
# Тестовые ключи (всегда проходят, для dev / CI):
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
#
# Если переменные не заданы — проверка пропускается (предупреждение в логах).
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=0x4AAAAAADESw9sHxSD74sny
CF_TURNSTILE_SECRET=0x4AAAAAADESwwpZl9p77glXAlR2dIM32_c

# ─────────────────────────────────────────────
# SMTP / Mail transport
# ─────────────────────────────────────────────

# Хост почтового сервера.
# В Docker Compose сервисы общаются по имени сервиса, не container_name.
# Staging (Mailpit): mailserver
# Production (внешний relay): smtp.mailgun.org / smtp.postmarkapp.com / etc.
SMTP_HOST=mailserver

# Порт SMTP:
# Staging Mailpit внутри Docker-сети: 1025
# Production relay STARTTLS: 587
# Production relay SSL: 465
SMTP_PORT=1025

# true  → SSL/TLS с самого начала соединения (порт 465)
# false → обычное соединение, STARTTLS по возможности
SMTP_SECURE=false

# Аутентификация: false — отключить auth полностью (внутренний relay).
# Если SMTP_USER / SMTP_PASS заданы, auth включается автоматически.
SMTP_AUTH=false
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────
# Адреса
# ─────────────────────────────────────────────

# Куда приходят входящие заявки (получатель / TO)
CONTACT_TO_EMAIL=hello@interlex.work

# От кого отправляются письма (From-заголовок)
CONTACT_FROM_EMAIL=noreply@host.ickz.net

# Скрытая копия на все письма (необязательно, можно оставить пустым)
CONTACT_BCC_EMAIL=

# ─────────────────────────────────────────────
# Search engine verification
# ─────────────────────────────────────────────
# Заполнить кодами из Google Search Console / Яндекс.Вебмастера / Bing Webmaster
# (только токен, без префиксов и без HTML-обёртки meta-тега).
# Если пусто — verification meta-теги не рендерятся.
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
